# ─── Secretos — NUNCA commitear claves ───────────────────────────
# La clave de Gemini (GEMINI_API_KEY) y cualquier credencial van en
# variables de entorno o en un .env local, jamás en el repositorio.
.env
.env.*
!.env.example
*.key
secrets.*
credentials.*

# ─── Python (entra con build_html.py / server.py) ────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# ─── Sistema operativo / editores ────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ─── Temporales / logs ───────────────────────────────────────────
*.log
*.tmp
